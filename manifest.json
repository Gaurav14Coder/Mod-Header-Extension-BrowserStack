{
  "manifest_version": 3,
  "name": "MOD HEADER BROWSERSTACK",
  "version": "4.0",
  "description": "Select a user email to fetch and apply their Mod Header",
  "permissions": [
     "tabs",
  "scripting",
  "activeTab",
  "storage",
  "declarativeNetRequest",
  "declarativeNetRequestWithHostAccess",
    "sidePanel"
  ],
  "host_permissions": [
    "*://www.browserstack.com/*",
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
 "action": {
  "default_icon": "icon.png"
},
"side_panel": {
  "default_path": "popup.html"
},
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "content.js"
      ],
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
